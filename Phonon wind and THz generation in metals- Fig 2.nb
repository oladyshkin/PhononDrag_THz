            RowBox[{"EzInterp", "[", "tt", "]"}], ",", "tt"}], "]"}], "/.", 
          " ", 
          RowBox[{"tt", "->", "t"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"dEzInterp", ",", "tValues"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"::", "Section", "::"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Data", " ", "generation"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"interp1", ",", "tVals1"}], "}"}], "=", 
     RowBox[{"solveForAlfa", "[", 
      RowBox[{"alfaValues", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"interp2", ",", "tVals2"}], "}"}], "=", 
     RowBox[{"solveForAlfa", "[", 
      RowBox[{"alfaValues", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"interp3", ",", "tVals3"}], "}"}], "=", 
     RowBox[{"solveForAlfa", "[", 
      RowBox[{"alfaValues", "[", 
       RowBox[{"[", "3", "]"}], "]"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"scale", "=", 
     RowBox[{"10", "^", "10"}]}], ";"}], "  ", 
   RowBox[{"(*", 
    RowBox[{"arbitrary", " ", "units", " ", "scaling"}], "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"::", "Section", "::"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", "Visualization", "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Time", " ", "domain", " ", "waveforms"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot1", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"interp1", "[", "t", "]"}], "/", "scale"}], ",", 
         RowBox[{
          RowBox[{"interp2", "[", "t", "]"}], "/", "scale"}], ",", 
         RowBox[{
          RowBox[{"interp3", "[", "t", "]"}], "/", "scale"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", 
         RowBox[{"2", "*", 
          RowBox[{"10", "^", 
           RowBox[{"-", "12"}]}]}]}], "}"}], ",", 
       RowBox[{"PlotRange", "->", "All"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Red", ",", "Thick"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Blue", ",", "Thick", ",", "Dotted"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Darker", "[", "Green", "]"}], ",", "Thick", ",", 
            "DotDashed"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Time (s)\>\"", 
          ",", "\"\<dE\\!\\(\\*SubscriptBox[\\(z\\), \\(\\)]\\)/dt (arb. \
u.)\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<THz waveforms\>\""}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"LineLegend", "[", 
           RowBox[{
            RowBox[{"{", 
             
             RowBox[{"\"\<\[Alpha] = 2\[Times]10^12\>\"", 
              ",", "\"\<\[Alpha] = 3\[Times]10^12\>\"", 
              ",", "\"\<\[Alpha] = 4\[Times]10^12\>\""}], "}"}], ",", 
            RowBox[{"LegendFunction", "->", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Framed", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"RoundingRadius", "->", "5"}], ",", 
                 RowBox[{"FrameStyle", "->", "LightGray"}]}], "]"}], "&"}], 
              ")"}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"0.8", ",", "0.8"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"ImageSize", "->", "400"}], ",", 
       RowBox[{"LabelStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FontFamily", "->", "\"\<Times\>\""}], ",", 
          RowBox[{"FontSize", "->", "12"}]}], "}"}]}], ",", 
       RowBox[{"FrameStyle", "->", "Thick"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Spectrum", " ", "calculation"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"computeSpectrum", "[", 
      RowBox[{"dEzInterp_", ",", "tMin_", ",", "tMax_", ",", "nPoints_"}], 
      "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "tData", ",", "ezData", ",", "ezData2", ",", "dt", ",", 
         "samplingRate", ",", "ft", ",", "freqs", ",", "amplitudeSpectrum"}], 
        "}"}], ",", 
       RowBox[{
        RowBox[{"tData", "=", 
         RowBox[{"Subdivide", "[", 
          RowBox[{"tMin", ",", "tMax", ",", 
           RowBox[{"nPoints", "-", "1"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ezData", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"dEzInterp", "[", "t", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"t", ",", "tData"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"ezData2", "=", 
         RowBox[{"ezData", "-", 
          RowBox[{"Mean", "[", "ezData", "]"}]}]}], ";", 
        RowBox[{"(*", 
         RowBox[{"remove", " ", "DC", " ", "component"}], "*)"}], 
        RowBox[{"dt", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"tMax", "-", "tMin"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"nPoints", "-", "1"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"samplingRate", "=", 
         RowBox[{"1", "/", "dt"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ft", "=", 
         RowBox[{"Fourier", "[", 
          RowBox[{"ezData2", ",", 
           RowBox[{"FourierParameters", "->", 
            RowBox[{"{", 
             RowBox[{"1", ",", 
              RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"freqs", "=", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"0", ",", 
            RowBox[{
             RowBox[{"nPoints", "/", "2"}], "-", "1"}]}], "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"samplingRate", "/", "nPoints"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"amplitudeSpectrum", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "/", "nPoints"}], ")"}], "*", 
          RowBox[{"Abs", "[", 
           RowBox[{"ft", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", 
              RowBox[{"nPoints", "/", "2"}]}], "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"freqs", ",", "amplitudeSpectrum"}], "}"}], "]"}]}]}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tMin", "=", "0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tMax", "=", "t0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nPoints", "=", 
     RowBox[{"2", "^", "10"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spec1", "=", 
     RowBox[{"computeSpectrum", "[", 
      RowBox[{"interp1", ",", "tMin", ",", "tMax", ",", "nPoints"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"spec2", "=", 
     RowBox[{"computeSpectrum", "[", 
      RowBox[{"interp2", ",", "tMin", ",", "tMax", ",", "nPoints"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"spec3", "=", 
     RowBox[{"computeSpectrum", "[", 
      RowBox[{"interp3", ",", "tMin", ",", "tMax", ",", "nPoints"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"scaleSpec", "[", "spec_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "/", "scale"}]}], "}"}], "&"}], "/@",
       "spec"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"spec1scaled", "=", 
     RowBox[{"scaleSpec", "[", "spec1", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spec2scaled", "=", 
     RowBox[{"scaleSpec", "[", "spec2", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spec3scaled", "=", 
     RowBox[{"scaleSpec", "[", "spec3", "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Frequency", " ", "spectra"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot2scaled", "=", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"spec1scaled", ",", "spec2scaled", ",", "spec3scaled"}], 
        "}"}], ",", 
