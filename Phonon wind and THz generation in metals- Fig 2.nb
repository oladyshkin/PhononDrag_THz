         RowBox[{"\"\<Frequency (Hz)\>\"", 
          ",", "\"\<Amplitude (arb. u.)\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Frequency Spectra\>\""}], ",", 
       RowBox[{"PlotLegends", "->", 
