             RowBox[{"\"\<\[Alpha] = 2\[Times]10^12\>\"", 
              ",", "\"\<\[Alpha] = 3\[Times]10^12\>\"", 
              ",", "\"\<\[Alpha] = 4\[Times]10^12\>\""}], "}"}], ",", 
